# Taifoon Solver Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git!

# === Wallet Configuration ===
# EVM private key (0x...)
SOLVER_PRIVATE_KEY=

# Solana keypair path
SOLANA_KEYPAIR_PATH=

# === Network Configuration ===
# Genome stream URL
GENOME_SSE_URL=https://api.taifoon.dev/api/genome/subscribe/sse

# Minimum profit threshold in USD
MIN_PROFIT_USD=1.0

# === RPC Endpoints ===
# Add your RPC endpoints here
# ETHEREUM_RPC=
# BASE_RPC=
# ARBITRUM_RPC=
# OPTIMISM_RPC=
# SOLANA_RPC_URL=

# === Optional ===
# Dry run mode (no actual transactions)
# DRY_RUN=true
