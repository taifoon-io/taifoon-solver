# pnpm config for the dashboard package.
#
# auto-install-peers — pulls in peer deps automatically (e.g. `siwe@^2`
# declares `ethers` as a peer; we want pnpm to install it without
# requiring an explicit entry on `dependencies`).
auto-install-peers=true

# strict-peer-dependencies — surface peer-version mismatches as errors
# at install time instead of letting them blow up at runtime. Trade a
# few install failures for build-time confidence.
strict-peer-dependencies=false

# Default to the public registry.
registry=https://registry.npmjs.org/

# Keep the global virtual store out of the project so the CI cache key
# (path: ~/.local/share/pnpm/store) works as expected.
shamefully-hoist=false
